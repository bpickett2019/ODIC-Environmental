# ============================================
# ODIC Environmental ESA Report System
# Configuration Example
# ============================================

# ---- AI BACKEND SELECTION ----
# Options: "ollama" (default, free), "anthropic" (paid)
AI_BACKEND=ollama

# ---- OLLAMA (LOCAL, FREE) ----
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_VL_MODEL=qwen2.5vl:7b
OLLAMA_CONCURRENCY=8

# ---- ANTHROPIC CLAUDE (OPTIONAL, PAID) ----
# Only needed if AI_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-...

# ---- DATABASE ----
# SQLite (default): sqlite:///./reports.db
# PostgreSQL (production): postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///./reports.db

# ---- SYSTEM TOOLS ----
TESSERACT_PATH=/usr/bin/tesseract
GHOSTSCRIPT_PATH=/usr/bin/gs
LIBREOFFICE_PATH=soffice

# ---- FILE HANDLING ----
COMPRESSION_DPI=150
MAX_EMAIL_SIZE_MB=10
MAX_STANDARD_SIZE_MB=25

# ---- FRONTEND API URL ----
VITE_API_URL=http://localhost:8000

# ---- FEATURES (OPTIONAL) ----
# Use Claude for tiebreaker classifications (when Ollama < 80% confident)
USE_CLAUDE_TIEBREAKER=false

# Use Claude for final QC validation
USE_CLAUDE_QC=false

# Use Claude for smart suggestions
USE_CLAUDE_SUGGESTIONS=false
